rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users — caller can read their own doc; only admin can change role.
    match /users/{userId} {
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.role == 'customer';
      allow update: if isAdmin()
        || (isOwner(userId) && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    // Templates — public read; admin write only.
    match /templates/{templateId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // Orders — clients NEVER write. Stripe webhook + free/admin flow use Admin SDK
    // which bypasses these rules. Owner can read their own orders.
    match /orders/{orderId} {
      allow read:   if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write:  if false;
    }

    // Events — public read (the invitation pages render via SSR + public RSVP page).
    // Only the owner (or admin) can mutate.
    match /events/{eventId} {
      allow read:   if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // RSVPs — guests submit without an account, but must point at a real event.
    // Read is restricted to the event owner / admin.
    match /rsvps/{rsvpId} {
      allow create: if request.resource.data.eventId is string
        && request.resource.data.eventId.size() > 0
        && exists(/databases/$(database)/documents/events/$(request.resource.data.eventId))
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.attending in ['yes', 'no'];
      allow read:   if isSignedIn() && (
        get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.userId == request.auth.uid
        || isAdmin()
      );
      allow update, delete: if isAdmin();
    }

    // Invitations — guest reads happen server-side via Admin SDK (bypasses rules),
    // so the client never needs read access to the collection.
    // Owners create/delete; guests can only flip status from pending → accepted.
    match /invitations/{invitationId} {
      allow read: if isSignedIn() && (
        get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.userId == request.auth.uid
        || isAdmin()
      );
      allow create: if isSignedIn() && (
        get(/databases/$(database)/documents/events/$(request.resource.data.eventId)).data.userId == request.auth.uid
        || isAdmin()
      );
      allow update: if (
        // Owner / admin: full update
        isSignedIn() && (
          get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.userId == request.auth.uid
          || isAdmin()
        )
      ) || (
        // Guest: only flip pending → accepted, nothing else may change
        resource.data.status == 'pending'
        && request.resource.data.status == 'accepted'
        && request.resource.data.eventId == resource.data.eventId
        && request.resource.data.token == resource.data.token
        && request.resource.data.guestName == resource.data.guestName
        && request.resource.data.createdAt == resource.data.createdAt
      );
      allow delete: if isSignedIn() && (
        get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.userId == request.auth.uid
        || isAdmin()
      );
    }
  }
}
